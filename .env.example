# Copie este arquivo para ".env" e preencha com os valores do seu projeto Supabase.
# Encontre-os em: Supabase → Project Settings → Data API (e API Keys).
# A chave "anon" é pública por design — não é segredo.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui
